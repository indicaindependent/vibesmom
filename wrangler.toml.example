# wrangler.toml.example
# Copy to wrangler.toml and fill in your values
# NEVER commit the real wrangler.toml with your account ID / database IDs

name = "your-worker-name"
main = "worker.js"
compatibility_date = "2024-01-01"
compatibility_flags = ["nodejs_compat"]

account_id = "YOUR_CF_ACCOUNT_ID"

# D1 Database (create with: wrangler d1 create your-db-name)
[[d1_databases]]
binding = "DB"
database_name = "your-db-name"
database_id = "YOUR_D1_DATABASE_ID"

# KV Namespace (create with: wrangler kv:namespace create your-kv)
[[kv_namespaces]]
binding = "KV"
id = "YOUR_KV_NAMESPACE_ID"

# Environment variables (non-secret)
[vars]
ENVIRONMENT = "production"

# Secrets (set with: wrangler secret put SECRET_NAME)
# BSKY_APP_PASS
# ANTHROPIC_API_KEY
# NEWS_API_KEY
# WORKER_SECRET

# Cron triggers
[triggers]
crons = ["0 15 * * *"]   # Daily at 3pm UTC (11am ET)

# Custom domain routes
[[routes]]
pattern = "yourdomain.com/*"
zone_name = "yourdomain.com"
